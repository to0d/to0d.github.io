<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />        
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>%%title%%</title>
    <link href="https://to0d.github.io/images/favicon.ico" rel="icon">
    <link rel="stylesheet" type="text/css" href="https://to0d.github.io/css/bootstrap.css">
    <link rel="stylesheet" type="text/css" href="https://to0d.github.io/css/font-awesome.min.css">
    <link rel="stylesheet" type="text/css" href="https://to0d.github.io/css/style.css">
</head>

<body>

<div class="navbar navbar-default navbar-fixed-top" role="navigation">
    <div class="container">
        <div class="navbar-header">
            <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-ex1-collapse">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
            </button>
            <a href="https://to0d.github.io/" class="navbar-brand"><img src="https://to0d.github.io/images/t.png" width="32"/>TODD's website</a>
        </div>
        <div class="collapse navbar-collapse navbar-ex1-collapse">
            <ul class="nav navbar-nav navbar-right">
                <li>
                    <a href="https://to0d.github.io/about">
                        <i class="fa fa-question"></i>
                        <span class="icon-label">About</span>
                    </a>
                </li>
                <li>
                    <a href="https://to0d.github.io/all">
                        <i class="fa fa-th-list"></i>
                        <span class="icon-label">All posts</span>
                    </a>
                </li>
            </ul>
        </div>
        <!-- /.navbar-collapse -->
    </div>
</div> <!-- /.navbar -->

<div class="container">
    <div class="row">
        <article>
            <h1>%%title%%</h1>

            <span class="published">
                <i class="fa fa-calendar"></i>
                <time> %%date%%</time>
            </span>
            <br/><br/>

            <div class="entry-content">
                %%content%%
            </div>
        </article>
    </div>
</div>

<footer>
   <div class="container">
      <hr>
      <div class="row">
         <div class="col-xs-10">
            &copy; 2019 <b><a href="mailto:to0d@outlook.com">TODD</a></b>
         </div>
         <div class="col-xs-2"><p class="pull-right"><i class="fa fa-arrow-up"></i> <a href="#">BACK</a></p></div>
      </div>
   </div>
</footer>
<script src="https://to0d.github.io/js/jquery-2.js"></script>
<script src="https://to0d.github.io/js/bootstrap.js"></script>
</body>
</html>